    "databaseBootstrapFailureWipe" : {
      "comment" : "Destructive button on the database bootstrap failure screen; deletes the local database. Action is confirmed via a dialog before proceeding.",
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Datenbank löschen"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wipe Database"
          }
        }
      }
    },
    "databaseBootstrapFailureWipeConfirmAction" : {
      "comment" : "Destructive confirmation button inside the wipe-database dialog. Tapping this actually performs the wipe.",
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Datenbank löschen"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wipe Database"
          }
        }
      }
    },
    "databaseBootstrapFailureWipeConfirmMessage" : {
      "comment" : "Explanatory text under the wipe-database confirmation title. Tells the user the action is destructive and resets the app's local state.",
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dies setzt den lokalen Zustand der App zurück. Möglicherweise müssen Sie sich danach erneut anmelden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This resets the app's local state. You may need to sign in again afterwards."
          }
        }
      }
    },
    "databaseBootstrapFailureWipeConfirmTitle" : {
      "comment" : "Title of the confirmation dialog shown before wiping the local database.",
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lokale Datenbank löschen?"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wipe local database?"
          }
        }
      }
    },
    "databaseBootstrapFailureWipeFailed" : {
      "comment" : "Prefix shown above the underlying error string when wiping the local database fails. Full message format: '<this string> <error description>'.",
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lokale Datenbank konnte nicht gelöscht werden:"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Couldn't wipe the local database:"
          }
        }
      }
    },
